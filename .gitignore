# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Terraform (temporary - ignores .tf files, state, and local caches)
# NOTE: .gitignore does not untrack files already committed. To remove tracked terraform files,
# run: git rm --cached <path> or use the commands in the project README.
*.tf
*.tfvars
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore the tf-acr and tf-aks directories (keep them locally, don't track in git)
tf-acr/
tf-aks/
