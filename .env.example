# Copy to .env and fill values for local development.
# Do not commit credentials. .env is gitignored.

# Postgres credentials used by docker-compose
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# App database URL (uncomment to override defaults)
# DATABASE_URL=postgresql://myuser:mypassword@postgres:5432/mydb
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>?schema=public&sslmode=disable

# Clerk (auth): add keys to .env for local testing
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/

# SQL seed-on-start (development only)
SQL_SEED_ON_START=false

# NOTE: Prisma runtime has been removed; schema and seeds live under `sql/`.
# PRISMA_STUDIO and related options are no longer used.

# If needed for local volumes (development only)
# CHOWN_ON_STARTUP=false
