# Example environment variables ONLY for LOCAL Terraform usage
# best to use azure cli login or service principal for CI  
# or use Entra ID with RBAC and store secrets in GitHub Actions secrets or Azure key vault.
# Copy this file to `.env` (or load it into your shell) and DO NOT commit your .env file.

# Terraform variables 
TF_VAR_acr_name=tnwregistry
TF_VAR_resource_group_name=tnw-rg
TF_VAR_location=eastus

# Optional: Azure Service Principal (recommended for CI)
# do NOT commit
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=

# Notes:
# - Keep this file local and add `.env` to your .gitignore.
# - Alternatively export TF_VAR_* directly in your shell instead of using a file.
